# IDE Development Environment Variables for Ingester
# Copy this to .env.local and load in your IDE run configuration
#
# IntelliJ IDEA: Run/Debug Configurations → Environment Variables → Load from file
# VSCode: Add to launch.json env section

# =============================================================================
# Platform Service Configuration
# =============================================================================
# Platform Service running locally (via IDE or Docker Compose)
TAKTX_PLATFORM_URL=http://localhost:8080

# =============================================================================
# Kafka Configuration
# =============================================================================
# Kafka running locally (via Docker Compose or standalone)
BOOTSTRAP_SERVERS=localhost:9092
TAKTX_ENGINE_NAMESPACE=namespace
TAKTX_CLIENT_GROUPID_INSTANCEUPDATE=taktx-ingesters-inmemory-instanceupdate

