# TaktX Docker Compose environment variables
#
# Master encryption key for RSA private key at-rest encryption (AES-256-GCM).
# Generate with: openssl rand -base64 32
# A DB dump alone cannot recover the private key without this value.
TAKTX_ENCRYPTION_MASTER_KEY=changeme-set-a-real-key-here

# Copy this to .env and customize for your setup

# =============================================================================
# Platform Service Configuration
# =============================================================================

# OIDC — platform service validates JWTs by fetching JWKS directly from Keycloak container
QUARKUS_OIDC_AUTH_SERVER_URL=http://keycloak:8080/realms/taktx

# Token validation (security critical)
# Audience must match the client ID in the token's "aud" claim
QUARKUS_OIDC_TOKEN_AUDIENCE=taktx-console
# Issuer must match the public issuer URL that Keycloak puts in tokens
QUARKUS_OIDC_TOKEN_ISSUER=http://localhost:8180/realms/taktx
# Role claim path (default: "roles", for Cognito use "cognito:groups")
# QUARKUS_OIDC_ROLES_ROLE_CLAIM_PATH=roles

# Database Configuration
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://postgres:5432/taktx_platform
QUARKUS_DATASOURCE_USERNAME=taktx
QUARKUS_DATASOURCE_PASSWORD=taktx

# Kafka Configuration
BOOTSTRAP_SERVERS=kafka:9094
TAKTX_ENGINE_NAMESPACE=namespace

# Credential Encryption Key
# Generate with: openssl rand -base64 32
TAKTX_ENCRYPTION_MASTER_KEY=dev-key-change-in-production

# =============================================================================
# Ingester Configuration
# =============================================================================

TAKTX_PLATFORM_URL=http://taktx-platform-service:8080

# =============================================================================
# Frontend Configuration
# =============================================================================

# Platform Service URL (empty string for relative URLs via nginx)
NEXT_PUBLIC_PLATFORM_SERVICE_URL=

# OIDC Provider Configuration
# Browser hits Keycloak directly on localhost:8180. No nginx proxy needed for auth.
# OIDC_ISSUER must match the iss claim Keycloak puts in tokens.
OIDC_ISSUER=http://localhost:8180/realms/taktx
OIDC_CLIENT_ID=taktx-console
OIDC_CLIENT_SECRET=taktx-console-secret
# NextAuth server-side uses container-internal hostname
OIDC_ISSUER_INTERNAL=http://keycloak:8080/realms/taktx
# Role claim path (default: "roles", for Cognito use "cognito:groups", for nested use "realm_access.roles")
# OIDC_ROLES_CLAIM_PATH=roles

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3002
# Generate with: openssl rand -base64 32
AUTH_SECRET=dev-secret-change-in-production
