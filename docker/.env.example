# Docker Compose environment variables for the TaktX Community Console
#
# Copy this file to `docker/.env` if you want to override image names or tags:
#
#   cd docker
#   cp .env.example .env
#
# Most runtime environment values for local development are defined directly in
# `docker-compose.yaml`. This file is primarily for Compose-time interpolation.

# -----------------------------------------------------------------------------
# Image source overrides
# -----------------------------------------------------------------------------

# Container registry hosting the published images.
DOCKER_REGISTRY=ghcr.io

# Image namespace / organization.
DOCKER_ORG=taktx-io

# Image tag to pull when not building locally.
IMAGE_TAG=0.2.0-beta-5

# -----------------------------------------------------------------------------
# Frontend build override
# -----------------------------------------------------------------------------

# Optional: bake an absolute Platform Service URL into the frontend image.
#
# Default (recommended): leave empty so the frontend uses relative `/api/*` URLs
# through nginx. This works on any host/domain without rebuilding the image.
#
# Set this only for images that will run WITHOUT a reverse proxy in front:
# NEXT_PUBLIC_PLATFORM_SERVICE_URL=http://localhost:8080
NEXT_PUBLIC_PLATFORM_SERVICE_URL=

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------

# The local compose stack currently hard-codes these runtime values directly in
# `docker-compose.yaml`:
#   - TAKTX_ENGINE_TENANT_ID=acme
#   - TAKTX_ENGINE_NAMESPACE=default
#   - BOOTSTRAP_SERVERS=kafka:9094
#
# If you need to change them, edit `docker-compose.yaml` (or add a Compose
# override file) so all related services stay consistent.
